RCON_API_TOKEN=
RCON_BASE_URL=https://seu-crcon.exemplo.com.br

# Deploy/producao via SSH
PROD_SSH_ADDRESS=root@72.60.254.177
PROD_PROJECT_DIR=/opt/hll-bots

# Bot settings
BOT_POLL_INTERVAL_MS=5000
BOT_LOG_WINDOW=1000
BOT_LOCK_FILE=artifacts/bot.lock
BOT_TOP_COMMAND_COOLDOWN_MS=15000
BOT_MATCH_ENDED_COOLDOWN_MS=300000
TOP_LIMIT=10
TOP_INCLUDE_HEADER=true
TOP_STATS_ENDPOINT=get_live_game_stats

# Safety switch
BOT_DRY_RUN=false

# Opcional: arquivo para persistir deduplicacao de MATCH ENDED entre restarts
BOT_STATE_FILE=artifacts/bot-state.json

# Local runner: sobe top + performance-info juntos com `npm run bots`
TOP_BOT_ENABLED=true
OP_BOT_ENABLED=true
PERFORMANCE_INFO_BOT_ENABLED=true
PERFORMANCE_BOT_ENABLED=false

# Comandos administrativos privados (!t, !tp, !classes e metricas por classe)
ENABLE_TEST_COMMANDS=false
ADMINISTRADOR_ID=

# Bot informativo de performance (!perf / !performance)
PERFORMANCE_INFO_DRY_RUN=false
PERFORMANCE_INFO_POLL_INTERVAL_MS=5000
PERFORMANCE_INFO_LOG_WINDOW=1000
PERFORMANCE_INFO_LOCK_FILE=artifacts/performance-info-bot.lock
PERFORMANCE_INFO_COMMAND_COOLDOWN_MS=15000

# Bot de performance em producao
# Use PERFORMANCE_PROCESS_MATCH_END=false em teste local para manter apenas comandos privados do admin.
PERFORMANCE_PROCESS_MATCH_END=true
PERFORMANCE_SEND_PUBLIC=true
PERFORMANCE_SEND_WINNER_PRIVATE=true
PERFORMANCE_GRANT_VIP=true
PERFORMANCE_VIP_EXPIRATION=3 days
PERFORMANCE_POLL_INTERVAL_MS=5000
PERFORMANCE_LOG_WINDOW=1000
PERFORMANCE_LOCK_FILE=artifacts/performance-bot.lock
PERFORMANCE_STATE_FILE=artifacts/performance-bot-state.json
PERFORMANCE_MATCH_ENDED_COOLDOWN_MS=300000
PERFORMANCE_STATS_ENDPOINT=get_live_game_stats
